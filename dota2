    <style>
        :root {
            --bg-color: #0a0c10;
            --card-bg: rgba(18, 20, 28, 0.65);
            --card-hover: rgba(24, 28, 38, 0.85);
            --primary: #ff3847;
            --primary-glow: rgba(255, 56, 71, 0.35);
            --secondary: #8a2be2;
            --text-main: #f5f6fa;
            --text-muted: #95a5a6;
            --border: rgba(255, 255, 255, 0.04);
            --border-hover: rgba(255, 56, 71, 0.3);
        }

        /* Плавное поведение скролла и кастомный скроллбар */
        html {
            scroll-behavior: smooth;
        }
        
        ::-webkit-scrollbar {
            width: 10px;
        }
        ::-webkit-scrollbar-track {
            background: var(--bg-color);
        }
        ::-webkit-scrollbar-thumb {
            background: #1c1f26;
            border-radius: 5px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: var(--primary);
        }

        body {
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
            margin: 0;
            padding: 0;
            background-color: var(--bg-color);
            color: var(--text-main);
            line-height: 1.6;
            overflow-x: hidden;
            position: relative;
        }

        a {
            text-decoration: none;
            color: var(--text-main);
            transition: all 0.3s ease;
        }

        /* Анимированный живой фон */
        .bg-animation {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -1;
            overflow: hidden;
            pointer-events: none;
        }

        .blob {
            position: absolute;
            border-radius: 50%;
            filter: blur(120px);
            opacity: 0.15;
            animation: float 20px infinite alternate ease-in-out;
        }

        .blob-1 {
            top: -10%;
            left: 20%;
            width: 500px;
            height: 500px;
            background: var(--primary);
            animation-duration: 25px;
        }

        .blob-2 {
            bottom: 10%;
            right: 10%;
            width: 600px;
            height: 600px;
            background: var(--secondary);
            animation-duration: 30px;
        }

        @keyframes float {
            0% { transform: translate(0, 0) scale(1); }
            50% { transform: translate(50px, 40px) scale(1.1); }
            100% { transform: translate(-30px, 80px) scale(0.9); }
        }

        /* Главный контейнер */
        .container {
            max-width: 1140px;
            margin: 0 auto;
            padding: 0 20px;
        }

        /* Навигация */
        nav {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 30px 0;
            border-bottom: 1px solid var(--border);
            animation: fadeInDown 1s ease forwards;
        }

        .logo {
            font-size: 1.4rem;
            font-weight: 800;
            letter-spacing: 1px;
            text-transform: uppercase;
            background: linear-gradient(90deg, #fff, #b4b4b4);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        
        .logo span {
            color: var(--primary);
            -webkit-text-fill-color: initial;
        }

        .nav-links {
            display: flex;
            gap: 30px;
        }

        .nav-links a {
            font-weight: 500;
            color: var(--text-muted);
            position: relative;
        }

        .nav-links a::after {
            content: '';
            position: absolute;
            width: 0;
            height: 2px;
            bottom: -5px;
            left: 0;
            background-color: var(--primary);
            transition: width 0.3s ease;
        }

        .nav-links a:hover::after {
            width: 100%;
        }

        .nav-links a:hover {
            color: #fff;
        }

        /* Кнопки */
        .btn {
            display: inline-block;
            background: linear-gradient(135deg, var(--primary) 0%, #d62839 100%);
            color: #fff;
            padding: 16px 36px;
            border-radius: 12px;
            font-weight: 600;
            transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
            box-shadow: 0 4px 15px var(--primary-glow);
            position: relative;
            overflow: hidden;
            z-index: 1;
        }

        .btn::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, #ff5766 0%, var(--primary) 100%);
            opacity: 0;
            transition: opacity 0.3s ease;
            z-index: -1;
        }

        .btn:hover {
            transform: translateY(-3px) scale(1.02);
            box-shadow: 0 8px 25px rgba(255, 56, 71, 0.6);
        }

        .btn:hover::before {
            opacity: 1;
        }

        .btn-outline {
            background: transparent;
            border: 2px solid var(--primary);
            box-shadow: none;
        }

        .btn-outline:hover {
            background: var(--primary);
            box-shadow: 0 4px 15px var(--primary-glow);
        }

        /* Главный экран */
        .hero {
            padding: 120px 0 80px;
            text-align: center;
        }

        .hero h1 {
            font-size: 4.2rem;
            font-weight: 900;
            margin-bottom: 25px;
            letter-spacing: -1px;
            background: linear-gradient(135deg, #ffffff 30%, #a3a8b4 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            animation: fadeInUp 1s ease forwards;
        }

        .hero p {
            font-size: 1.3rem;
            color: var(--text-muted);
            max-width: 750px;
            margin: 0 auto 40px;
            animation: fadeInUp 1.2s ease forwards;
        }

        .hero-buttons {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-bottom: 70px;
            animation: fadeInUp 1.4s ease forwards;
        }

        /* Блок статистики */
        .stats {
            display: flex;
            justify-content: space-around;
            background: var(--card-bg);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid var(--border);
            padding: 40px;
            border-radius: 24px;
            text-align: center;
            gap: 20px;
            animation: fadeInUp 1.6s ease forwards;
        }

        .stat-item h3 {
            font-size: 2.5rem;
            color: var(--primary);
            margin: 0 0 5px 0;
            font-weight: 800;
            letter-spacing: -1px;
        }

        .stat-item p {
            margin: 0;
            color: var(--text-muted);
            font-size: 1rem;
            font-weight: 500;
        }

        /* Секции общего назначения */
        .section {
            padding: 100px 0;
        }

        .section-header {
            text-align: center;
            margin-bottom: 60px;
        }

        .section-header h2 {
            font-size: 2.8rem;
            font-weight: 800;
            margin-bottom: 15px;
            background: linear-gradient(90deg, #fff, #ced4da);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .section-header p {
            color: var(--text-muted);
            font-size: 1.15rem;
        }

        /* Карточки преимуществ */
        .features-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 30px;
        }

        .feature-card {
            background: var(--card-bg);
            backdrop-filter: blur(15px);
            -webkit-backdrop-filter: blur(15px);
            border: 1px solid var(--border);
            padding: 45px 35px;
            border-radius: 24px;
            transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        }

        .feature-card:hover {
            background: var(--card-hover);
            border-color: var(--border-hover);
            transform: translateY(-8px);
            box-shadow: 0 15px 40px rgba(255, 56, 71, 0.1);
        }

        .feature-card .num {
            font-size: 1.1rem;
            font-weight: 700;
            color: var(--primary);
            background: rgba(255, 56, 71, 0.12);
            padding: 6px 16px;
            border-radius: 8px;
            display: inline-block;
            margin-bottom: 25px;
        }

        .feature-card h3 {
            margin: 0 0 15px 0;
            font-size: 1.5rem;
            font-weight: 700;
        }

        .feature-card p {
            margin: 0;
            color: var(--text-muted);
            font-size: 1rem;
        }

        /* Обучение */
        .training {
            display: flex;
            align-items: center;
            gap: 70px;
            flex-wrap: wrap;
        }

        .training-img {
            flex: 1;
            min-width: 320px;
            position: relative;
        }

        .training-img img {
            width: 100%;
            border-radius: 24px;
            box-shadow: 0 20px 50px rgba(0,0,0,0.4);
            border: 1px solid var(--border);
            transition: transform 0.5s ease;
        }

        .training-img:hover img {
            transform: scale(1.02) rotate(1deg);
        }

        .training-content {
            flex: 1;
            min-width: 320px;
        }

        .badge {
            background: rgba(138, 43, 226, 0.15);
            color: #b066ff;
            padding: 6px 16px;
            border-radius: 30px;
            font-weight: 600;
            font-size: 0.9rem;
            display: inline-block;
            margin-bottom: 25px;
            border: 1px solid rgba(138, 43, 226, 0.3);
        }

        .training-content ul {
            list-style: none;
            padding: 0;
            margin: 30px 0 40px;
        }

        .training-content ul li {
            margin-bottom: 18px;
            padding-left: 35px;
            position: relative;
            font-size: 1.05rem;
        }

        .training-content ul li::before {
            content: '✓';
            position: absolute;
            left: 5px;
            top: 0;
            color: var(--primary);
            font-weight: 900;
            font-size: 1.2rem;
        }

        /* Аккордеон FAQ */
        .faq-wrapper {
            max-width: 850px;
            margin: 0 auto;
        }

        details {
            background: var(--card-bg);
            backdrop-filter: blur(10px);
            border: 1px solid var(--border);
            margin-bottom: 18px;
            border-radius: 16px;
            padding: 10px 25px;
            transition: all 0.3s ease;
        }

        details:hover {
            border-color: rgba(255, 255, 255, 0.1);
            background: var(--card-hover);
        }

        details[open] {
            border-color: var(--border-hover);
            background: rgba(14, 16, 22, 0.95);
        }

        summary {
            padding: 20px 0;
            font-size: 1.25rem;
            font-weight: 600;
            cursor: pointer;
            list-style: none;
            position: relative;
            outline: none;
        }

        summary::-webkit-details-marker { display: none; }

        summary::after {
            content: '→';
            position: absolute;
            right: 0;
            color: var(--primary);
            font-size: 1.3rem;
            transition: transform 0.3s ease;
        }

        details[open] summary::after {
            transform: rotate(90deg);
        }

        details p {
            padding: 0 0 20px 0;
            margin: 0;
            color: var(--text-muted);
            border-top: 1px solid var(--border);
            padding-top: 20px;
            animation: fadeIn 0.4s ease forwards;
        }

        /* Блок CTA */
        .cta-banner {
            text-align: center; 
            background: linear-gradient(135deg, rgba(255,56,71,0.05) 0%, rgba(138,43,226,0.05) 100%);
            border: 1px solid var(--border);
            padding: 70px 30px;
            border-radius: 32px;
            backdrop-filter: blur(10px);
        }

        /* Футер */
        footer {
            background-color: #050608;
            padding: 70px 0;
            text-align: center;
            border-top: 1px solid var(--border);
            margin-top: 100px;
        }

        .footer-nav {
            display: flex;
            justify-content: center;
            gap: 30px;
            margin: 30px 0;
        }

        .footer-nav a {
            color: var(--text-muted);
            font-weight: 500;
        }

        .footer-nav a:hover {
            color: var(--primary);
        }

        /* Анимации */
        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @keyframes fadeInDown {
            from { opacity: 0; transform: translateY(-20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        /* Адаптивность */
        @media (max-width: 768px) {
            .nav-links { display: none; }
            .hero h1 { font-size: 2.8rem; }
            .hero p { font-size: 1.1rem; }
            .stats { flex-direction: column; gap: 35px; padding: 30px; }
            .training { flex-direction: column-reverse; gap: 40px; }
            .hero-buttons { flex-direction: column; gap: 15px; }
            .btn { width: 100%; box-sizing: border-box; text-align: center; }
        }
    </style>
</head>
